#!/bin/sh


set -e
: "${IPKG_INSTROOT:=}"

. /lib/functions.sh

CONF_DIR="/etc/nordvpn/config"
CONF="$CONF_DIR/nord.conf"
WG_NORD_BIN="/usr/bin/wg-nord"

LOG_FILE="/var/log/nordvpn.log"
STATUS_FILE="/var/run/nordvpn.status"
UI_STATUS_FILE="/var/run/nordvpn-ui.json"

VPN_IFACE="nordwg"
VPN_MARK="0x1234/0xffff"
VPN_TABLE="51820"
VPN_RULE_PRIO="10000"

QUIET="0"

TOKEN=""
PRIMARY_SERVER=""
SERVER_LIST=""
TARGET_INTERFACES=""

PRIV=""
ADDR=""
DNSV=""
PUB=""
ENDP=""
ALLOWED=""
KA=""
ENDPOINT_HOST=""
ENDPOINT_PORT=""

ensure_runtime() {
	mkdir -p "$CONF_DIR" /var/run /var/log
	touch "$LOG_FILE"
}

log_raw() {
	printf '%s [nordvpnctl] %s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "$*" >> "$LOG_FILE"
}

say() {
	log_raw "$*"
	[ "$QUIET" = "1" ] && return 0
	echo "[nordvpnctl] $*"
}

client_msg() {
	log_raw "$*"
	echo "$*"
}

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

append_server() {
	local v="$1"
	[ -n "$v" ] || return 0

	if [ -z "$SERVER_LIST" ]; then
		SERVER_LIST="$v"
	else
		SERVER_LIST="$SERVER_LIST $v"
	fi
}

append_target_iface() {
	local v="$1"
	[ -n "$v" ] || return 0

	if [ -z "$TARGET_INTERFACES" ]; then
		TARGET_INTERFACES="$v"
	else
		TARGET_INTERFACES="$TARGET_INTERFACES $v"
	fi
}

load_settings() {
	TOKEN=""
	PRIMARY_SERVER=""
	SERVER_LIST=""
	TARGET_INTERFACES=""

	config_load nordvpn

	config_get TOKEN settings token ""
	config_list_foreach settings server append_server
	config_list_foreach settings target_interfaces append_target_iface

	# Backward compatibility in case old config still has single option server
	if [ -z "$SERVER_LIST" ]; then
		config_get PRIMARY_SERVER settings server ""
		if [ -n "$PRIMARY_SERVER" ]; then
			SERVER_LIST="$PRIMARY_SERVER"
		fi
	fi

	[ -n "$SERVER_LIST" ] || SERVER_LIST="si14.nordvpn.com"

	set -- $SERVER_LIST
	PRIMARY_SERVER="${1:-si14.nordvpn.com}"
}

require_token() {
	load_settings
	if [ -z "$TOKEN" ]; then
		say "ERROR: NordVPN token is empty in UCI (nordvpn.settings.token)."
		exit 1
	fi
}

target_interfaces_json() {
	local json=""
	local item

	for item in $TARGET_INTERFACES; do
		if [ -n "$json" ]; then
			json="$json, "
		fi
		json="$json\"$(json_escape "$item")\""
	done

	printf '[%s]' "$json"
}

current_server_url() {
	load_settings

	if [ -f "$CONF" ]; then
		local s
		s="$(sed -n 's/^Endpoint[[:space:]]*=[[:space:]]*//p' "$CONF" | head -n1 | cut -d: -f1)"
		[ -n "$s" ] && echo "$s" && return 0
	fi

	echo "$PRIMARY_SERVER"
}

is_connected() {
	if uci -q get network."$VPN_IFACE" >/dev/null 2>&1 && \
	   uci -q get firewall.nord >/dev/null 2>&1 && \
	   ip link show "$VPN_IFACE" >/dev/null 2>&1; then
		return 0
	fi

	return 1
}

write_plain_status() {
	local state="$1"
	local server="$2"

	case "$state" in
		connected)
			echo "Connected to $server" > "$STATUS_FILE"
			;;
		connecting)
			echo "Connecting to $server" > "$STATUS_FILE"
			;;
		*)
			echo "Disconnected" > "$STATUS_FILE"
			;;
	esac
}
delete_vpn_peer_sections() {
	local section
	local ifname

	for section in $(uci show network 2>/dev/null | sed -n "s/^\(network\.[^.]*\)=wireguard_${VPN_IFACE}$/\1/p" | cut -d. -f2); do
		uci -q delete "network.$section" || true
	done

	# extra safety for anonymous / weird leftovers
	for section in $(uci show network 2>/dev/null | sed -n 's/^\(network\.\@wireguard_[^[]*\[[0-9]\+\]\)=wireguard_[^ ]*$/\1/p'); do
		ifname="$(uci -q get "${section}.public_key" 2>/dev/null || true)"
		# no need to inspect much here, if it's wireguard_nordwg we delete it
		case "$section" in
			network.@wireguard_${VPN_IFACE}*)
				uci -q delete "$section" || true
			;;
		esac
	done
}
write_ui_status() {
	load_settings

	local state="${1:-}"
	local server external_ip vpn_external_ip

	server="$(current_server_url)"
	external_ip=""
	vpn_external_ip=""

	if [ -z "$state" ]; then
		if is_connected; then
			state="connected"
		else
			state="disconnected"
		fi
	fi

	cat > "$UI_STATUS_FILE" <<EOF
{
  "state": "$(json_escape "$state")",
  "server": "$(json_escape "$server")",
  "applied_interfaces": $(target_interfaces_json),
  "external_ip": "$(json_escape "$external_ip")",
  "vpn_external_ip": "$(json_escape "$vpn_external_ip")"
}
EOF

	write_plain_status "$state" "$server"
}

sanitize_name() {
	printf '%s' "$1" | tr -c 'A-Za-z0-9_' '_'
}

extract_from_conf() {
	PRIV="$(sed -n 's/^PrivateKey[[:space:]]*=[[:space:]]*//p' "$CONF" | head -n1)"
	ADDR="$(sed -n 's/^Address[[:space:]]*=[[:space:]]*//p' "$CONF" | head -n1)"
	DNSV="$(sed -n 's/^DNS[[:space:]]*=[[:space:]]*//p' "$CONF" | head -n1)"

	PUB="$(sed -n 's/^PublicKey[[:space:]]*=[[:space:]]*//p' "$CONF" | head -n1)"
	ENDP="$(sed -n 's/^Endpoint[[:space:]]*=[[:space:]]*//p' "$CONF" | head -n1)"
	ALLOWED="$(sed -n 's/^AllowedIPs[[:space:]]*=[[:space:]]*//p' "$CONF" | head -n1)"
	KA="$(sed -n 's/^PersistentKeepalive[[:space:]]*=[[:space:]]*//p' "$CONF" | head -n1)"

	if [ -z "$PRIV" ] || [ -z "$PUB" ] || [ -z "$ENDP" ]; then
		say "FAILED: Missing required fields in $CONF (PrivateKey/PublicKey/Endpoint)."
		exit 1
	fi

	ENDPOINT_HOST="$(printf '%s' "$ENDP" | cut -d: -f1)"
	ENDPOINT_PORT="$(printf '%s' "$ENDP" | awk -F: '{print $NF}')"

	if [ -z "$ENDPOINT_HOST" ] || [ -z "$ENDPOINT_PORT" ]; then
		say "FAILED: Could not parse Endpoint host/port from: $ENDP"
		exit 1
	fi
}

require_conf() {
	if [ ! -f "$CONF" ]; then
		say "ERROR: Config file not found at $CONF"
		say "Run --gen-config first."
		exit 1
	fi
}

cleanup_network_objects() {
	uci -q delete network."$VPN_IFACE" || true
	uci -q delete network."${VPN_IFACE}_peer" || true
	uci -q delete network."${VPN_IFACE}_default_route" || true
	uci -q delete network."${VPN_IFACE}_mark_rule" || true
        delete_vpn_peer_sections
}

cleanup_firewall_objects() {
	uci -q delete firewall.nord || true

	local sect
	for sect in $(uci show firewall 2>/dev/null | sed -n 's/^\(firewall\.nord[^.=]*\)=.*$/\1/p' | cut -d. -f2 | sort -u); do
		uci -q delete "firewall.$sect" || true
	done
}

create_or_update_iface() {
	extract_from_conf

	cleanup_network_objects

	uci set network."$VPN_IFACE"='interface'
	uci set network."$VPN_IFACE".proto='wireguard'
	uci set network."$VPN_IFACE".private_key="$PRIV"
	uci set network."$VPN_IFACE".auto='1'

	if [ -n "$ADDR" ]; then
		uci -q delete network."$VPN_IFACE".addresses
		echo "$ADDR" | tr ',' '\n' | while IFS= read -r a; do
			a="$(echo "$a" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
			[ -n "$a" ] && uci add_list network."$VPN_IFACE".addresses="$a"
		done
	fi

	uci set network."${VPN_IFACE}_peer"="wireguard_$VPN_IFACE"
	uci set network."${VPN_IFACE}_peer".public_key="$PUB"
	uci set network."${VPN_IFACE}_peer".endpoint_host="$ENDPOINT_HOST"
	uci set network."${VPN_IFACE}_peer".endpoint_port="$ENDPOINT_PORT"

	uci -q delete network."${VPN_IFACE}_peer".allowed_ips
	if echo "$ALLOWED" | grep -q '0.0.0.0/0'; then
		echo "$ALLOWED" | tr ',' '\n' | while IFS= read -r ip; do
			ip="$(echo "$ip" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
			[ -n "$ip" ] && uci add_list network."${VPN_IFACE}_peer".allowed_ips="$ip"
		done
	else
		uci add_list network."${VPN_IFACE}_peer".allowed_ips='0.0.0.0/0'
	fi

	if [ -n "$KA" ]; then
		uci set network."${VPN_IFACE}_peer".persistent_keepalive="$KA"
	fi
}

apply_policy_routing() {
	uci set network."${VPN_IFACE}_default_route"='route'
	uci set network."${VPN_IFACE}_default_route".interface="$VPN_IFACE"
	uci set network."${VPN_IFACE}_default_route".target='0.0.0.0/0'
	uci set network."${VPN_IFACE}_default_route".table="$VPN_TABLE"

	uci set network."${VPN_IFACE}_mark_rule"='rule'
	uci set network."${VPN_IFACE}_mark_rule".mark="$VPN_MARK"
	uci set network."${VPN_IFACE}_mark_rule".lookup="$VPN_TABLE"
	uci set network."${VPN_IFACE}_mark_rule".priority="$VPN_RULE_PRIO"
}

apply_firewall_for_targets() {
	load_settings

	cleanup_firewall_objects

	uci set firewall.nord='zone'
	uci set firewall.nord.name='nord'
	uci add_list firewall.nord.network="$VPN_IFACE"
	uci set firewall.nord.input='REJECT'
	uci set firewall.nord.output='ACCEPT'
	uci set firewall.nord.forward='REJECT'
	uci set firewall.nord.masq='1'
	uci set firewall.nord.mtu_fix='1'

	local iface safe
	for iface in $TARGET_INTERFACES; do
		safe="$(sanitize_name "$iface")"

		uci set firewall."nord_fwd_${safe}"='forwarding'
		uci set firewall."nord_fwd_${safe}".src="$iface"
		uci set firewall."nord_fwd_${safe}".dest='nord'

		uci set firewall."nord_mark_${safe}"='rule'
		uci set firewall."nord_mark_${safe}".name="NORDWG mark $iface traffic"
		uci set firewall."nord_mark_${safe}".src="$iface"
		uci set firewall."nord_mark_${safe}".dest='*'
		uci set firewall."nord_mark_${safe}".proto='all'
		uci set firewall."nord_mark_${safe}".target='MARK'
		uci set firewall."nord_mark_${safe}".set_mark="$VPN_MARK"

		uci set firewall."nord_killswitch_${safe}"='rule'
		uci set firewall."nord_killswitch_${safe}".name="KillSwitch block $iface to WAN"
		uci set firewall."nord_killswitch_${safe}".src="$iface"
		uci set firewall."nord_killswitch_${safe}".dest='wan'
		uci set firewall."nord_killswitch_${safe}".proto='all'
		uci set firewall."nord_killswitch_${safe}".target='REJECT'
	done
}

action_gen_config() {
	ensure_runtime
	require_token
	write_ui_status "connecting"

	say "Step 1/1: Generating NordVPN WireGuard config -> $CONF"

	"$WG_NORD_BIN" --server "$PRIMARY_SERVER" --token "$TOKEN" > "$CONF"

	say "OK: Config generated."
	write_ui_status
}

action_create_iface() {
	ensure_runtime
	require_conf

	say "Loading config: $CONF"
	create_or_update_iface

	say "Committing network changes..."
	uci commit network

	say "Reloading network service..."
	/etc/init.d/network reload

	say "OK: $VPN_IFACE interface created/updated."
	say "Endpoint: $ENDPOINT_HOST:$ENDPOINT_PORT"
	write_ui_status
}

action_route_vpn() {
	ensure_runtime
	require_conf
	load_settings

	write_ui_status "connecting"

	say "Loading config: $CONF"
	create_or_update_iface
	apply_policy_routing
	apply_firewall_for_targets

	say "Committing firewall changes..."
	uci commit firewall
	say "Committing network changes..."
	uci commit network

	say "Restarting firewall service..."
	/etc/init.d/firewall restart
	say "Reloading network service..."
	/etc/init.d/network reload

	say "OK: Selected interfaces routed via NordVPN ($VPN_IFACE)."
	say "Endpoint: $ENDPOINT_HOST:$ENDPOINT_PORT"

	write_ui_status "connected"
}

action_route_default() {
	ensure_runtime
	write_ui_status "connecting"

	say "Disconnecting and reverting NordVPN routing..."

	cleanup_firewall_objects
	cleanup_network_objects

	say "Committing firewall changes..."
	uci commit firewall
	say "Committing network changes..."
	uci commit network

	say "Restarting firewall service..."
	/etc/init.d/firewall restart
	say "Reloading network service..."
	/etc/init.d/network reload

	ip rule del fwmark "$VPN_MARK" lookup "$VPN_TABLE" priority "$VPN_RULE_PRIO" 2>/dev/null || true
	ip route flush table "$VPN_TABLE" 2>/dev/null || true

	say "OK: Revert completed."
	write_ui_status "disconnected"
}

action_auto() {
	if [ ! -f "$CONF" ]; then
		say "Auto mode: config not found, generating..."
		action_gen_config
	else
		say "Auto mode: config exists ($CONF), skipping generation."
	fi

	action_route_vpn
}

action_status() {
	ensure_runtime
	write_ui_status

	local server
	server="$(current_server_url)"

	if is_connected; then
		client_msg "Connected to $server"
		return 0
	fi

	client_msg "Disconnected"
	return 1
}

action_c_connect() {
	local server
	ensure_runtime
	load_settings
	server="$(current_server_url)"

	write_ui_status "connecting"
	QUIET="1"
	printf "  Connecting to %s... " "$server"

	if action_auto >/dev/null 2>&1; then
		:
	else
		local rc="$?"
		QUIET="0"
		write_ui_status "disconnected"
		client_msg "Failed to connect!"
		exit "$rc"
	fi

	QUIET="0"

	if is_connected; then
		write_ui_status "connected"
		echo "Connected to $server"
		return 0
	fi

	write_ui_status "disconnected"
	echo "Failed to connect!"
	exit 1
}

action_d_disconnect() {
	ensure_runtime
	client_msg "Disconnecting from NordVPN."
	QUIET="1"

	if action_route_default >/dev/null 2>&1; then
		:
	else
		local rc="$?"
		QUIET="0"
		write_ui_status "disconnected"
		client_msg "Failed to disconnect!"
		exit "$rc"
	fi

	QUIET="0"
	write_ui_status "disconnected"
}

menu() {
	while true; do
		echo ""
		echo "1) Generate new NordVPN config"
		echo "2) Create NordVPN interface"
		echo "3) Route traffic via NordVPN interface"
		echo "4) Route traffic via default interface"
		echo "5) Status"
		echo "0) Exit"
		printf "Select: "
		read -r choice

		case "$choice" in
			1) action_gen_config ;;
			2) action_create_iface ;;
			3) action_route_vpn ;;
			4) action_route_default ;;
			5) action_status || true ;;
			0) exit 0 ;;
			*) echo "Invalid option." ;;
		esac
	done
}

ensure_runtime

if [ "${1:-}" = "" ]; then
	menu
	exit 0
fi

case "${1:-}" in
	--gen-config)      action_gen_config ;;
	--create-iface)    action_create_iface ;;
	--route-vpn)       action_route_vpn ;;
	--route-default)   action_d_disconnect ;;
	--auto)            action_c_connect ;;
	c)                 action_c_connect ;;
	d)                 action_d_disconnect ;;
	status)            action_status ;;
	-h|--help)
		echo "Usage:"
		echo "  $0                (interactive menu)"
		echo "  $0 --gen-config"
		echo "  $0 --create-iface"
		echo "  $0 --route-vpn"
		echo "  $0 --route-default"
		echo "  $0 --auto"
		echo "  $0 c"
		echo "  $0 d"
		echo "  $0 status"
		;;
	*)
		echo "Unknown argument: ${1:-}"
		exit 1
		;;
esac
