config main 'settings'
	option enabled '1'
	option token_file '/etc/nordvpn/config/token'
	option conf_file '/etc/nordvpn/config/nord.conf'
	option server 'si14.nordvpn.com'
	option auto_refresh '1'
	option refresh_days '3'
	option auto_connect '0'
	option interface_name 'nordvpn'
	option status_file '/var/run/nordvpn.status'
